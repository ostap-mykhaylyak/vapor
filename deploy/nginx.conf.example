# Esempio nginx + php-fpm per Vapor (produzione).
# Serve la dashboard e fa da reverse proxy WebSocket verso il terminal server.
# Procedura di deploy completa e variabili d'ambiente: vedi HOWTO.md.

upstream vapor_terminal {
    server 127.0.0.1:8090;
}

server {
    listen 443 ssl http2;
    server_name vapor.example.com;

    ssl_certificate     /etc/ssl/vapor/fullchain.pem;
    ssl_certificate_key /etc/ssl/vapor/privkey.pem;

    root /opt/vapor/public;
    index index.php;

    # Asset statici e front controller.
    location / {
        try_files $uri /index.php$is_args$args;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        # Stessi valori della unit systemd. VAPOR_SECRET DEVE coincidere
        # con quello del terminal server.
        fastcgi_param INCUS_SOCKET  /var/lib/incus/unix.socket;
        fastcgi_param INCUS_PROJECT default;
        fastcgi_param VAPOR_DB      /opt/vapor/storage/vapor.sqlite;
        fastcgi_param VAPOR_SECRET  CAMBIAMI-con-un-valore-casuale-lungo;
        # URL pubblico del WebSocket (TLS -> wss, stesso host).
        fastcgi_param VAPOR_WS_URL  wss://vapor.example.com/ws;
    }

    # Proxy WebSocket del terminale PTY.
    location /ws {
        proxy_pass http://vapor_terminal;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400s;
    }
}
