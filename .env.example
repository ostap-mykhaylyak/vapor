# Configurazione di Vapor — copia in ".env" e adatta i valori.
#
# Sorgente unica con PRIORITÀ MASSIMA per CLI e servizi:
#  - la CLI/web la legge automaticamente da questo file;
#  - i servizi systemd la caricano con EnvironmentFile=/opt/vapor/.env.
# I valori qui DEFINITI sovrascrivono qualunque altra variabile d'ambiente.
#
# Formato compatibile con systemd: KEY=value, niente "export", niente spazi
# attorno a "=", commenti su righe a sé.

# --- Connessione a Incus ---
# Modalità A (socket locale): lascia INCUS_HTTPS vuoto/assente.
INCUS_SOCKET=/var/lib/incus/unix.socket
INCUS_PROJECT=default

# Modalità B (HTTPS): scommenta e valorizza per collegarsi via rete.
#INCUS_HTTPS=https://mio-host:8443
#INCUS_CLIENT_CERT=/opt/vapor/storage/certs/client.crt
#INCUS_CLIENT_KEY=/opt/vapor/storage/certs/client.key
#INCUS_VERIFY=false

# --- Server WebSocket del terminale ---
VAPOR_WS_HOST=127.0.0.1
VAPOR_WS_PORT=8090
VAPOR_WS_URL=ws://127.0.0.1:8090
# Origin consentite (anti CSWSH) in produzione, es:
#VAPOR_WS_ORIGINS=https://vapor.example.com

# --- App ---
# CAMBIA con un valore lungo e casuale; identico per web e terminal server.
VAPOR_SECRET=cambiami-con-un-valore-casuale-lungo
VAPOR_DB=/opt/vapor/storage/vapor.sqlite
VAPOR_SESSION_TTL=28800
VAPOR_DEBUG=false
