# Normalizzazione automatica: git rileva i file di testo e li archivia con LF,
# evitando avvisi di codifica/fine-riga su Windows (CRLF) e Linux (LF).
* text=auto eol=lf

# Tipi di testo espliciti (sempre LF nel repo).
*.php        text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.html       text eol=lf
*.svg        text eol=lf
*.conf       text eol=lf
*.example    text eol=lf
*.service    text eol=lf
*.sql        text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf
.htaccess    text eol=lf

# Eseguibili CLI senza estensione.
bin/vapor    text eol=lf

# File binari: nessuna conversione di fine-riga né diff testuale.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.sqlite     binary
*.crt        binary
*.key        binary
*.pem        binary

# Asset di terze parti (xterm.js vendored): esclusi dalle statistiche di
# linguaggio di GitHub e segnalati come generati nei diff.
public/assets/vendor/** linguist-vendored
public/assets/vendor/**/*.min.js  -diff
